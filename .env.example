# ============================================================
# PLANTILLA ECOMMERCE - Variables de Entorno
# Copiar este archivo a .env.local y completar los valores
# ============================================================

# --- BASE DE DATOS ---
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/mi-tienda?retryWrites=true&w=majority

# --- AUTENTICACIÓN JWT ---
JWT_SECRET=tu_secreto_jwt_muy_largo_y_seguro_minimo_32_chars

# --- SETUP INICIAL (ejecutar POST /api/setup una sola vez tras el primer deploy) ---
# SETUP_SECRET debe ser una cadena aleatoria larga y segura
SETUP_SECRET=mi_secreto_de_setup_muy_seguro_cambiar_esto

# --- SUPERADMIN (Credenciales del primer usuario — se crean via /api/setup) ---
SUPERADMIN_EMAIL=superadmin@tudominio.com
SUPERADMIN_PASSWORD=CambiarEstePasswordInmediatamente123!
SUPERADMIN_NOMBRE=Super
SUPERADMIN_APELLIDO=Admin

# --- FIREBASE (Authentication) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-side)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- MERCADOPAGO ---
MP_ACCESS_TOKEN=TEST-...
MP_PUBLIC_KEY=TEST-...
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-...

# --- PICKIT (Envíos) ---
PICKIT_API_KEY=
PICKIT_TOKEN=
PICKIT_ENVIRONMENT=sandbox
# sandbox | production
PICKIT_COUNTRY=ar
# ar | uy | mx | co | cl | pe

# --- CLOUDINARY (Imágenes) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# --- EMAIL (Nodemailer) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu@gmail.com
EMAIL_PASS=tu_app_password

# --- URLS ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000
